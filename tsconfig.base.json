{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@iot-workspace/source"],
    "paths": {
      "@iot-workspace/shared": ["./shared/src/index.ts"],
      "@iot-workspace/interfaces": ["./shared/interfaces/src/index.ts"],
      "@iot-workspace/data-access": ["./frontend/data-access/src/index.ts"],
      "@iot-workspace/ui": ["./frontend/ui/src/index.ts"],
      "@iot-workspace/utils": ["./frontend/utils/src/index.ts"],
      "@iot-workspace/core": ["./backend/core/src/index.ts"],
      "@iot-workspace/frontend-utils": ["./frontend/utils/src/index.ts"],
      "@iot-workspace/backend-utils": ["./backend/utils/src/index.ts"]
    }
  }
}
